# Copy to .env when running the Docker stack.

TZ=Europe/Prague

# Leave empty to use the backend mock library.
# Set to /music to use the mounted music folder from MUSIC_LIBRARY_PATH.
MEDIA_LIBRARY_PATH=

# Host path or symlink that will be mounted into the backend container as /music.
MUSIC_LIBRARY_PATH=./runtime/music

HAJUKEBOX_MQTT_CLIENT_ID=hajukebox-backend
HAJUKEBOX_MQTT_TOPIC_PREFIX=jukebox

VITE_HA_BASE_URL=http://127.0.0.1:8123
VITE_HA_TOKEN=
VITE_HA_MODE=mock

# Optional Spotify bonus path
HAJUKEBOX_SPOTIFY_CLIENT_ID=
HAJUKEBOX_SPOTIFY_REDIRECT_URI=
HAJUKEBOX_SPOTIFY_FRONTEND_REDIRECT_URI=
HAJUKEBOX_SPOTIFY_SCOPES=
HAJUKEBOX_SPOTIFY_MOCK_MODE=
